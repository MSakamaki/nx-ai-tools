{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai-metrics config",
  "description": "Schema for .ai/metrics/metrics.config.json. Every field is optional and falls back to its default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "metricsRoot": {
      "type": "string",
      "default": ".ai/metrics"
    },
    "eventsDir": {
      "type": "string",
      "default": ".ai/metrics/events"
    },
    "generatedDir": {
      "type": "string",
      "default": ".ai/metrics/generated"
    },
    "hooksDir": {
      "type": "string",
      "default": ".ai/metrics/hooks"
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 4321
        }
      }
    },
    "showPromptBody": {
      "type": "boolean",
      "default": true
    },
    "showResponseBody": {
      "type": "boolean",
      "default": true
    },
    "markdownRendering": {
      "type": "boolean",
      "default": false
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claudeCode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "copilot": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "rawEvent": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "maxBytes": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 1048576
                }
              }
            }
          }
        }
      }
    }
  }
}
