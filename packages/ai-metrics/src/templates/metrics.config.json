{
  "metricsRoot": ".ai/metrics",
  "eventsDir": ".ai/metrics/events",
  "generatedDir": ".ai/metrics/generated",
  "hooksDir": ".ai/metrics/hooks",
  "report": {
    "port": 4321
  },
  "showPromptBody": true,
  "showResponseBody": true,
  "markdownRendering": false,
  "providers": {
    "claudeCode": {
      "enabled": true
    },
    "copilot": {
      "enabled": true,
      "rawEvent": {
        "enabled": true,
        "maxBytes": 1048576
      }
    }
  }
}
